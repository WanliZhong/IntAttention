+++ b/src/cpu/kernels/softmax/generic/neon/s32_signed.cpp	(revision a1c9ed62c082fc1dc407c261eeb013328c0579a2)
@@ -0,0 +1,34 @@
+#include "arm_compute/core/Helpers.h"
+
+#include "src/cpu/kernels/softmax/generic/neon/impl.h"
+
+namespace arm_compute
+{
+namespace cpu
+{
+template <bool IS_LOG>
+void neon_s32_index_softmax(const ITensor *in,
+                                 void *const    tmp,
+                                 ITensor       *out,
+                                 const float    beta,
+                                 int            axis,
+                                 const Window  &window,
+                                 const void    *lut_ptr)
+{
+    ARM_COMPUTE_UNUSED(lut_ptr);
+    if (axis == 0)
+    {
+        return neon_index_softmax_x_quantized<IS_LOG>(in, tmp, out, beta, axis, window);
+    }
+}
+
+template void neon_s32_index_softmax<false>(const ITensor *in,
+                                             void *const    tmp,
+                                             ITensor       *out,
+                                             const float    beta,
+                                             int            axis,
+                                             const Window  &window,
+                                             const void    *lut_ptr);
+
+} // namespace cpu
+} // namespace arm_compute
